<?xml version="1.0" encoding="utf-8"?>
<!--
  Para obtener más información acerca de cómo configurar una aplicación ASP.NET, consulte 
  http://go.microsoft.com/fwlink/?LinkId=301879
  -->
<configuration>
  <configSections>
    <!-- For more information on Entity Framework configuration, visit http://go.microsoft.com/fwlink/?LinkID=237468 -->
    <section name="entityFramework" type="System.Data.Entity.Internal.ConfigFile.EntityFrameworkSection, EntityFramework, Version=6.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" requirePermission="false" />
  <sectionGroup name="elmah">
      <section name="security" requirePermission="false" type="Elmah.SecuritySectionHandler, Elmah" />
      <section name="errorLog" requirePermission="false" type="Elmah.ErrorLogSectionHandler, Elmah" />
      <section name="errorMail" requirePermission="false" type="Elmah.ErrorMailSectionHandler, Elmah" />
      <section name="errorFilter" requirePermission="false" type="Elmah.ErrorFilterSectionHandler, Elmah" />
    </sectionGroup></configSections>
  <appSettings file=".\secretos.config">
    <add key="webpages:Version" value="3.0.0.0" />
    <add key="webpages:Enabled" value="false" />
    <add key="ClientValidationEnabled" value="true" />
    <add key="UnobtrusiveJavaScriptEnabled" value="true" />
    <!-- Configuración Verifacti (proveedor Verifactu).
         Habilitado=true desde el 20/07/26: es la fase en SOMBRA (#41). La clave empieza por
         "vf_test_", que ServicioVerifacti reconoce como sandbox, así que las facturas se registran
         contra el entorno de pruebas de la AEAT (prewww2.aeat.es) y NO tienen efecto fiscal.
         El QR lleva además su propia guarda: GestorFacturas.EsQrDeProduccion rechaza cualquier URL
         con "prewww", de modo que un QR de sandbox no se imprime jamás.
         Estaba a false en el repo y a true en el servidor (se activó editando el Web.config en
         vivo); se sube aquí para que el despliegue no apague la sombra sin querer.
         Para pasar a producción hay que cambiar la ApiKey por una "vf_live_", no este flag. -->
    <add key="Verifacti:ApiKey" value="vf_test_qESaoRRR7Oq2MJgyTeVcc07WoeDcogPb4vpVA9lYYFo=" />
    <add key="Verifacti:BaseUrl" value="https://api.verifacti.com/" />
    <add key="Verifacti:Habilitado" value="true" />
    <!-- Innovatrans: WebService DataTrans DTX. Lo NO sensible va aquí; la password (de la que se
         calcula clave = MD5(password)) va en secretos.config como "InnovatransPassword". -->
    <add key="Innovatrans:Url" value="http://h001.iatsl.es:8081/dtxSW/services/" />
    <!-- GLS/ASM: uid (GUID de cliente) para el tracking GetExpCli. Hoy el de BusinessParcel (servicio 96),
         que es como salen casi todos los envíos. Solo lectura de seguimiento, no es secreto. -->
    <add key="GLS:UidSeguimiento" value="6fb665f2-15a2-4478-9804-c1556fc1f272" />
    <!-- El identificador (nº de cliente DataTrans) vive en AgenciaTransporte.Identificador (fila 12),
         como en las demás agencias. La empresa (código DTX) es config de conexión y se queda aquí. -->
    <add key="Innovatrans:Empresa" value="91253" />
    <add key="Innovatrans:Email" value="carlosadrian@nuevavision.es" />
    <!-- Remitente fijo (nuestro almacén de Algete) para los envíos de Innovatrans. -->
    <add key="Innovatrans:Remitente:Nombre" value="NUEVA VISIÓN, S.A." />
    <add key="Innovatrans:Remitente:Telefono" value="916281914" />
    <add key="Innovatrans:Remitente:CodigoPostal" value="28119" />
    <add key="Innovatrans:Remitente:Poblacion" value="ALGETE" />
    <add key="Innovatrans:Remitente:Direccion" value="Río Tiétar, 11, Pol. Ind. El Nogal" />
  <add key="elmah.mvc.disableHandler" value="false" />
    <add key="elmah.mvc.disableHandleErrorFilter" value="false" />
    <add key="elmah.mvc.requiresAuthentication" value="false" />
    <add key="elmah.mvc.IgnoreDefaultRoute" value="false" />
    <add key="elmah.mvc.allowedRoles" value="*" />
    <add key="elmah.mvc.allowedUsers" value="*" />
    <add key="elmah.mvc.route" value="logs-nestoapi" />
    <add key="elmah.mvc.UserAuthCaseSensitive" value="true" />
    <!-- Issue #74: Correos post-compra semanales -->
    <add key="CorreosPostCompra:ModoTest" value="false" />
    <add key="CorreosPostCompra:EmailsTest" value="manuelrodriguez@nuevavision.es,laura@nuevavision.es,carlosadrian@nuevavision.es" />
    <add key="CorreosPostCompra:Remitente" value="nuevavision@nuevavision.es" />
    <!-- NestoAPI#225: rotación automática de credenciales LWA de Amazon SP-API.
         Las credenciales AWS IAM (AmazonSpApiAccessKey / AmazonSpApiSecretKey) van en
         secretos.config (NO commitear). Aquí solo lo no sensible. -->
    <add key="AmazonSpApi:SqsQueueUrl" value="https://sqs.eu-west-1.amazonaws.com/190854240256/sp-api-credential-rotation" />
    <add key="AmazonSpApi:Region" value="eu-west-1" />
    <add key="AmazonSpApi:EuEndpoint" value="https://sellingpartnerapi-eu.amazon.com" />
    <add key="AmazonSpApi:LwaTokenEndpoint" value="https://api.amazon.com/auth/o2/token" />
    <add key="AmazonSpApi:RotacionDiasAntes" value="15" />
  </appSettings>

  <!-- Configuración de Elmah para logging de errores -->
  <elmah>
    <security allowRemoteAccess="true" />
    <errorLog type="Elmah.SqlErrorLog, Elmah" connectionStringName="NestoConnection" applicationName="NestoAPI" />
    <!-- NestoAPI#183: las cancelaciones de cliente (móvil pierde red, app en background,
         patrones takeUntil/switchMap de RxJS) son inevitables en HTTP y ensucian ELMAH
         con ruido que no aporta nada. Filtramos OperationCanceledException (y por
         herencia TaskCanceledException) para que los errores reales queden visibles.

         Sintaxis: <is-type-compatible> usa Elmah.Assertions.TypeAssertion con
         byCompatibility=true (equivale a `is OperationCanceledException`, así que
         cubre también TaskCanceledException por herencia).
         La versión original con <equal binding="BaseException.GetType().FullName" ...>
         dependía de WebDataBindingExpression (DataBinder.Eval), que no soporta
         llamadas a método y silenciosamente abortaba la cadena de logging,
         dejando ELMAH sin registrar errores reales. -->
    <!-- NestoAPI#336: el 38% del log del último mes eran escaneos de bots a rutas que no
         existen (/wp-admin, /.git/config, /actuator, /.aws/credentials...). Se filtran SOLO
         los "controlador no encontrado" (404 de enrutado) cuya ruta case con patrones de
         escaneo conocidos: un 404 legítimo (un cliente llamando a una ruta nuestra
         eliminada) se sigue registrando porque su ruta no casa con ningún patrón.

         IMPORTANTE: se filtra sobre BaseException.Message (que ya incluye la ruta) y NO
         sobre Context.Request.Path, porque Context es null en errores señalados fuera de
         una petición HTTP (jobs de Hangfire) y un binding que lanza ABORTA en silencio
         toda la cadena de logging de ELMAH (lección de #183). El mensaje nunca es null. -->
    <errorFilter>
      <test>
        <or>
          <is-type-compatible binding="BaseException" type="System.OperationCanceledException" />
          <and>
            <!-- Nombre de ensamblado COMPLETO obligatorio: HttpException no está en mscorlib
                 y Type.GetType sin ensamblado no lo resuelve (lo caza el test del filtro). -->
            <is-type-compatible binding="BaseException" type="System.Web.HttpException, System.Web, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a" />
            <!-- /\.(?!well-known) casa cualquier directorio oculto raíz (/.stripe/, /.cursor/,
                 /.aider/...) menos /.well-known, que es legítimo (assetlinks del deep linking #107). -->
            <regex binding="BaseException.Message" pattern="No se encuentra el controlador de la ruta de acceso '[^']*(wp-|wordpress|\.git|\.env|\.aws|\.ssh|\.vscode|actuator|phpmyadmin|_ignition|graphi?ql|server-status|nginx_status|/solr|/silk|/debug/|api-docs|/health|index\.php|\.php'|/\.(?!well-known)|_debugbar|_profiler|/_wdt|__debug__|/telescope|/playground|/adminer|kibana|/grafana|/hawtio|/_cat/|Dockerfile|/error_log|/backups?/|/dbadmin|/db/'|/admin|/phpinfo|AhmadScanner)" />
          </and>
        </or>
      </test>
    </errorFilter>
  </elmah>

  <!--
    Para obtener una descripción de los cambios de web.config, vea http://go.microsoft.com/fwlink/?LinkId=235367.

    Los siguientes atributos se pueden establecer en la etiqueta <httpRuntime>.
      <system.Web>
        <httpRuntime targetFramework="4.8" />
      </system.Web>
  -->

  <system.web>
    <customErrors mode="Off" />
    <compilation debug="true" targetFramework="4.8" />
    <!-- NestoAPI#336 (fase 2): no anunciar la versión de ASP.NET a los escáneres -->
    <httpRuntime targetFramework="4.5" enableVersionHeader="false" />
    <httpModules>
      <add name="TelemetryCorrelationHttpModule" type="Microsoft.AspNet.TelemetryCorrelation.TelemetryCorrelationHttpModule, Microsoft.AspNet.TelemetryCorrelation" />
      <add name="ApplicationInsightsWebTracking" type="Microsoft.ApplicationInsights.Web.ApplicationInsightsHttpModule, Microsoft.AI.Web" />
      <add name="ErrorLog" type="Elmah.ErrorLogModule, Elmah" />
      <add name="ErrorMail" type="Elmah.ErrorMailModule, Elmah" />
      <add name="ErrorFilter" type="Elmah.ErrorFilterModule, Elmah" />
    </httpModules>
  </system.web>
