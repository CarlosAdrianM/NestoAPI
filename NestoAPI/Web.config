      <provider invariantName="System.Data.SqlClient" type="System.Data.Entity.SqlServer.SqlProviderServices, EntityFramework.SqlServer" />
    </providers>
  </entityFramework>
  <system.webServer>
	  <security>
		  <authentication>
			  <windowsAuthentication enabled="true" />
			  <anonymousAuthentication enabled="true" />
		  </authentication>
      <!-- NestoAPI#336 (fase 2): bloqueo REAL de los escaneos de bots. Request Filtering corta
           la petición en IIS, ANTES del pipeline de ASP.NET: el bot recibe un 404.5 seco, no se
           ejecuta código nuestro y no ensucia ELMAH. Son secuencias que NUNCA aparecen en rutas
           legítimas de la API (mismos patrones que el errorFilter de ELMAH, que se mantiene como
           segunda red para lo que no case aquí). removeServerHeader oculta la cabecera Server
           para no anunciar la tecnología (IIS 10+). -->
      <requestFiltering removeServerHeader="true">
        <denyUrlSequences>
          <add sequence=".php" />
          <add sequence="wp-" />
          <add sequence="wordpress" />
          <add sequence=".git" />
          <add sequence=".env" />
          <add sequence=".aws" />
          <add sequence=".ssh" />
          <add sequence=".vscode" />
          <add sequence="phpmyadmin" />
          <add sequence="actuator" />
          <add sequence="_ignition" />
          <add sequence="graphql" />
          <add sequence="server-status" />
          <add sequence="nginx_status" />
          <add sequence="/solr" />
          <add sequence="/cgi-bin" />
          <!-- Sondas a endpoints de profiling de Go (net/http/pprof y expvar): /debug/pprof/, /debug/vars -->
          <add sequence="/debug/" />
          <!-- Barrido de diccionario del 22/07: directorios ocultos y herramientas de debug/admin
               que jamás aparecen en rutas legítimas de la API (OJO: /.well-known NO se bloquea). -->
          <add sequence=".stripe" />
          <add sequence=".aider" />
          <add sequence=".cursor" />
          <add sequence=".codeium" />
          <add sequence=".windsurf" />
          <add sequence="_debugbar" />
          <add sequence="_profiler" />
          <add sequence="__debug__" />
          <add sequence="/adminer" />
          <add sequence="/hawtio" />
          <add sequence="/phpinfo" />
        </denyUrlSequences>
      </requestFiltering>
	  </security>
    <validation validateIntegratedModeConfiguration="false" />
    <modules>
		<remove name="FormsAuthentication" />
		<remove name="WindowsAuthentication" />
		<add name="WindowsAuthentication" type="System.Web.Security.WindowsAuthenticationModule" />
      <remove name="TelemetryCorrelationHttpModule" />
      <add name="TelemetryCorrelationHttpModule" type="Microsoft.AspNet.TelemetryCorrelation.TelemetryCorrelationHttpModule, Microsoft.AspNet.TelemetryCorrelation" preCondition="managedHandler" />
      <remove name="ApplicationInsightsWebTracking" />
      <add name="ApplicationInsightsWebTracking" type="Microsoft.ApplicationInsights.Web.ApplicationInsightsHttpModule, Microsoft.AI.Web" preCondition="managedHandler" />
      <add name="ErrorLog" type="Elmah.ErrorLogModule, Elmah" preCondition="managedHandler" />
      <add name="ErrorMail" type="Elmah.ErrorMailModule, Elmah" preCondition="managedHandler" />
      <add name="ErrorFilter" type="Elmah.ErrorFilterModule, Elmah" preCondition="managedHandler" />
    </modules>
    <handlers>
      <remove name="ExtensionlessUrlHandler-Integrated-4.0" />
      <remove name="OPTIONSVerbHandler" />
      <remove name="TRACEVerbHandler" />
      <add name="ExtensionlessUrlHandler-Integrated-4.0" path="*." verb="*" type="System.Web.Handlers.TransferRequestHandler" preCondition="integratedMode,runtimeVersionv4.0" />
      <!-- Issue #107: Permitir que .well-known/assetlinks.json sea servido por MVC (Android App Links) -->
      <add name="AssetLinksHandler" path=".well-known/assetlinks.json" verb="GET" type="System.Web.Handlers.TransferRequestHandler" preCondition="integratedMode,runtimeVersionv4.0" />
      <!-- Issue #116: Permitir que pago/ok.html y ko.html sean servidos por Web API (redireccion Redsys) -->
      <add name="PagoRedirectHandler" path="pago/*.html" verb="GET" type="System.Web.Handlers.TransferRequestHandler" preCondition="integratedMode,runtimeVersionv4.0" />
      <add name="Elmah" path="elmah.axd" verb="POST,GET,HEAD" type="Elmah.ErrorLogPageFactory, Elmah" preCondition="integratedMode" />
    </handlers>
    <!-- NestoAPI#336 (fase 2): no anunciar la tecnología a los escáneres -->
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>